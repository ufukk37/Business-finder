# Uygulama Ayarları
APP_NAME=İşletme Keşif Platformu
DEBUG=True

# Veritabanı
# PostgreSQL bağlantı string'i
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/business_finder

# Google Places API
# https://console.cloud.google.com/ adresinden API key alınmalı
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Arama Ayarları
DEFAULT_SEARCH_RADIUS=5000
MAX_SEARCH_RADIUS=50000
MAX_RESULTS_PER_SEARCH=60

# CORS - Frontend URL'leri
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# n8n Webhook (opsiyonel)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/business-search

# Önbellek
CACHE_TTL=3600

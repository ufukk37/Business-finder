# Uygulama Ayarları
APP_NAME=İşletme Keşif Platformu
DEBUG=True

# Veritabanı - SQLite kullanıyoruz (kurulum gerektirmez)
DATABASE_URL=sqlite+aiosqlite:///./business_finder.db

# OpenStreetMap kullanıyoruz - API KEY GEREKMEZ! Tamamen ücretsiz.

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Arama Ayarları
DEFAULT_SEARCH_RADIUS=5000
MAX_SEARCH_RADIUS=50000
MAX_RESULTS_PER_SEARCH=100

# Önbellek
CACHE_TTL=3600
